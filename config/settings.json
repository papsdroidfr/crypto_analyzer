{
  "_comment": "Configuration CryptoAnalyzer — éditez ce fichier pour personnaliser le comportement.",

  "symbols": [
    "BTCUSDC",
    "ETHUSDC",
    "SOLUSDC",
    "TAOUSDC",
    "BNBUSDC"
  ],

  "timeframes": [
    {
      "value": "1h",
      "label": "1 heure",
      "candles_chart": 48
    },
    {
      "value": "1d",
      "label": "24 heures",
      "candles_chart": 60
    },
    {
      "value": "1w",
      "label": "1 semaine",
      "candles_chart": 26
    }
  ],

  "charts_output_dir": "charts_output",

  "discord": {
    "webhook_url": "MON WEBHOOK DISCORD ICI",
    "username": "CryptoAnalyzer 🤖"
  },

  "hourly_variation": {
    "threshold_pct": 2.0,
    "severity": "WARNING"
  },

  "alerts": [
    {
      "_comment": "RSI 7 en surachat extrême (> 80) — signal fort",
      "name": "rsi7_extreme_overbought",
      "type": "threshold",
      "timeframes": [
        "1d"
      ],
      "lookback_periods": 1,
      "severity": "CRITICAL",
      "message_tpl": "🚨 RSI_7 surachat extrême sur {symbol} [{tf}] — RSI = {rsi_7}",
      "conditions": [
        {
          "indicator": "rsi_7",
          "operator": ">",
          "value": 80,
          "agg": "last"
        }
      ]
    },

    {
      "_comment": "RSI 7 en survente extrême (< 20) — signal fort",
      "name": "rsi7_extreme_oversold",
      "type": "threshold",
      "timeframes": [
        "1d"
      ],
      "lookback_periods": 1,
      "severity": "CRITICAL",
      "message_tpl": "🚨 RSI_7 survente extrême sur {symbol} [{tf}] — RSI = {rsi_7}",
      "conditions": [
        {
          "indicator": "rsi_7",
          "operator": "<",
          "value": 20,
          "agg": "last"
        }
      ]
    },

    {
      "_comment": "Compression de Bollinger (faible volatilité, breakout imminent)",
      "name": "bollinger_squeeze",
      "type": "threshold",
      "timeframes": [
        "1d"
      ],
      "lookback_periods": 1,
      "severity": "INFO",
      "message_tpl": "🔀 Compression Bollinger sur {symbol} [{tf}] — Width={bb_width}",
      "conditions": [
        {
          "indicator": "bb_width",
          "operator": "<",
          "value": 0.05,
          "agg": "last"
        }
      ]
    },

    {
      "_comment": "Combo fort : RSI 7 et 14 tous les deux en surachat + MACD haussier",
      "name": "strong_bullish_combo",
      "type": "threshold",
      "timeframes": [
        "1d"
      ],
      "lookback_periods": 1,
      "severity": "CRITICAL",
      "message_tpl": "🚀 Signal haussier fort sur {symbol} [{tf}] — RSI7={rsi_7} RSI14={rsi_14} MACD={macd_hist}",
      "conditions": [
        {
          "indicator": "rsi_7",
          "operator": ">",
          "value": 65,
          "agg": "last"
        },
        {
          "indicator": "rsi_14",
          "operator": ">",
          "value": 60,
          "agg": "last"
        },
        {
          "indicator": "macd_hist",
          "operator": ">",
          "value": 0,
          "agg": "last"
        }
      ]
    }
  ]
}
